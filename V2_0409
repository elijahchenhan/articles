<title>飛航模飾 — 文章新增工具 v3</title>
<link href="./飛航模飾 — 文章新增工具 v3_files/css2" rel="stylesheet">
<style>
:root {
  --navy:#1E2D3D; --navy-mid:#2C3E52; --slate:#3D5166;
  --accent:#B8956A; --accent-light:#D4B896; --accent-pale:#F0E8DC;
  --cream:#F5EFE5; --warm-white:#FAF8F4; --border:#E0D8CE;
  --text:#2C3A48; --text-light:#6B7C8D; --muted:#8A9BAA;
  --success:#4A8F6A; --error:#C0504A;
  --font-display:'DM Serif Display','Noto Serif TC',serif;
  --font-serif:'Noto Serif TC',serif;
  --font-body:'Noto Sans TC',sans-serif;
  --radius:12px;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{font-size:16px;}
body{font-family:var(--font-body);background:var(--warm-white);color:var(--text);min-height:100vh;-webkit-font-smoothing:antialiased;}

/* ── Header ── */
.header{background:var(--navy);padding:18px 32px;display:flex;align-items:center;gap:16px;border-bottom:1px solid rgba(184,149,106,.2);}
.header-logo{font-family:var(--font-display);font-size:20px;color:var(--accent-light);letter-spacing:.06em;}
.header-sub{font-size:11px;color:rgba(255,255,255,.35);letter-spacing:.12em;text-transform:uppercase;padding-left:16px;border-left:1px solid rgba(255,255,255,.1);}
.header-badge{margin-left:auto;background:rgba(184,149,106,.2);color:var(--accent-light);font-size:11px;padding:4px 14px;border-radius:50px;letter-spacing:.06em;white-space:nowrap;}

.main{max-width:1160px;margin:0 auto;padding:32px 24px 80px;display:flex;flex-direction:column;gap:24px;}

/* ── Panel ── */
.panel{background:#fff;border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;}
.panel-header{background:var(--navy);padding:14px 22px;display:flex;align-items:center;gap:10px;}
.panel-icon{width:26px;height:26px;background:rgba(184,149,106,.2);border-radius:7px;display:flex;align-items:center;justify-content:center;color:var(--accent-light);font-size:13px;flex-shrink:0;}
.panel-title{font-family:var(--font-serif);font-size:15px;font-weight:400;color:#fff;letter-spacing:.04em;flex:1;}
.panel-hint{font-size:11px;color:rgba(255,255,255,.35);}
.panel-body{padding:22px;}

/* ── Paste area ── */
.paste-area{width:100%;min-height:100px;padding:14px;border:2px dashed var(--border);border-radius:10px;font-family:'Menlo','Monaco',monospace;font-size:11.5px;line-height:1.6;color:var(--text-light);background:var(--warm-white);outline:none;resize:vertical;transition:border-color .2s,background .2s;}
.paste-area:focus{border-color:var(--accent);background:#fff;}
.paste-area.loaded{border-color:var(--success);border-style:solid;background:#f8fbf9;}

.status-bar{display:flex;align-items:center;gap:8px;padding:9px 13px;border-radius:8px;font-size:12.5px;margin-top:10px;}
.status-bar.success{background:#f0f8f3;color:var(--success);border:1px solid rgba(74,143,106,.2);}
.status-bar.error{background:#fdf2f2;color:var(--error);border:1px solid rgba(192,80,74,.2);}
.status-bar.idle{background:var(--accent-pale);color:var(--accent);border:1px solid rgba(184,149,106,.2);}

/* ── Queue area ── */
.queue-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
.queue-title-row{display:flex;align-items:center;gap:10px;}
.queue-count{display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;background:var(--navy);color:var(--accent-light);border-radius:50%;font-size:12px;font-weight:600;}
.queue-label{font-size:13px;font-weight:500;color:var(--text);}

.queue-list{display:flex;flex-direction:column;gap:8px;margin-bottom:16px;min-height:0;}
.queue-empty{text-align:center;padding:28px;color:var(--muted);font-size:13px;border:1.5px dashed var(--border);border-radius:10px;}

/* Article card in queue */
.q-card{display:flex;align-items:flex-start;gap:12px;padding:13px 15px;border:1px solid var(--border);border-radius:10px;background:var(--warm-white);transition:box-shadow .18s;}
.q-card:hover{box-shadow:0 2px 12px rgba(28,45,62,.07);}
.q-num{font-family:var(--font-display);font-size:20px;color:var(--accent-light);min-width:22px;text-align:center;flex-shrink:0;line-height:1.2;}
.q-body{flex:1;min-width:0;}
.q-title{font-family:var(--font-serif);font-size:14px;font-weight:500;color:var(--navy);margin-bottom:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.q-meta{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.q-tag{font-size:10px;letter-spacing:.08em;text-transform:uppercase;padding:2px 8px;border-radius:50px;background:var(--accent-pale);color:var(--accent);font-weight:500;}
.q-info{font-size:11px;color:var(--muted);}
.q-remove{flex-shrink:0;width:26px;height:26px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:14px;transition:all .18s;}
.q-remove:hover{background:#fdf2f2;border-color:rgba(192,80,74,.3);color:var(--error);}

/* ── Form ── */
.form-section{border:1.5px solid var(--border);border-radius:10px;padding:20px;background:var(--warm-white);}
.form-section-title{font-size:12px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:16px;display:flex;align-items:center;gap:8px;}
.form-section-title::after{content:'';flex:1;height:1px;background:var(--border);}

.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.form-grid.three{grid-template-columns:1fr 1fr 1fr;}
.field{display:flex;flex-direction:column;gap:5px;}
.field.full{grid-column:1/-1;}
label{font-size:11px;font-weight:500;letter-spacing:.09em;text-transform:uppercase;color:var(--muted);}
label .req{color:var(--accent);margin-left:2px;}
input[type="text"],input[type="date"],input[type="number"],select,textarea{
  padding:9px 12px;border:1.5px solid var(--border);border-radius:8px;
  font-family:var(--font-body);font-size:13.5px;color:var(--text);
  background:#fff;outline:none;transition:border-color .2s;width:100%;
}
input:focus,select:focus,textarea:focus{border-color:var(--accent);}
textarea{resize:vertical;min-height:72px;line-height:1.6;}
.field-hint{font-size:11px;color:var(--muted);line-height:1.5;}

/* Tag selector */
.tag-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:5px;}
.tag-opt{display:none;}
.tag-opt+label{display:flex;align-items:center;justify-content:center;padding:7px 4px;border:1.5px solid var(--border);border-radius:7px;font-size:11.5px;font-weight:400;letter-spacing:.02em;text-transform:none;color:var(--text-light);cursor:pointer;transition:all .15s;text-align:center;}
.tag-opt:checked+label{background:var(--navy);border-color:var(--navy);color:#fff;}
.tag-opt+label:hover{border-color:var(--accent);color:var(--accent);}

/* Pos grid */
.pos-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:4px;}
.pos-opt{display:none;}
.pos-opt+label{display:block;padding:5px 2px;border:1.5px solid var(--border);border-radius:6px;font-size:10.5px;letter-spacing:.02em;text-transform:none;color:var(--text-light);cursor:pointer;transition:all .15s;text-align:center;}
.pos-opt:checked+label{background:var(--accent-pale);border-color:var(--accent);color:var(--accent);font-weight:500;}

/* ── Buttons ── */
.btn{padding:11px 20px;border-radius:9px;font-family:var(--font-serif);font-size:14px;font-weight:400;letter-spacing:.04em;cursor:pointer;border:none;transition:all .2s;display:inline-flex;align-items:center;justify-content:center;gap:7px;white-space:nowrap;}
.btn-primary{background:var(--navy);color:#fff;}
.btn-primary:hover{background:var(--slate);transform:translateY(-1px);}
.btn-secondary{background:var(--accent-pale);color:var(--accent);border:1.5px solid rgba(184,149,106,.3);}
.btn-secondary:hover{background:var(--accent);color:#fff;}
.btn-outline{background:transparent;color:var(--text-light);border:1.5px solid var(--border);}
.btn-outline:hover{border-color:var(--accent);color:var(--accent);}
.btn-success{background:var(--success);color:#fff;}
.btn-success:hover{opacity:.9;transform:translateY(-1px);}
.btn-sm{padding:7px 14px;font-size:12px;border-radius:7px;}

.btn-row{display:flex;gap:10px;flex-wrap:wrap;}

/* ── Output ── */
.output-meta-bar{display:flex;align-items:center;gap:12px;padding:12px 16px;background:#f0f8f3;border:1px solid rgba(74,143,106,.2);border-radius:9px;margin-bottom:14px;flex-wrap:wrap;}
.output-meta-item{font-size:12.5px;color:var(--success);display:flex;align-items:center;gap:5px;}
.output-meta-item strong{font-weight:600;}

.code-wrap{background:#1a2433;border-radius:10px;padding:18px;position:relative;overflow:auto;max-height:280px;}
.code-wrap pre{font-family:'Menlo','Monaco',monospace;font-size:11.5px;line-height:1.7;color:#C8D8E8;white-space:pre;}
.btn-copy{position:sticky;float:right;top:0;padding:5px 13px;background:rgba(184,149,106,.2);border:1px solid rgba(184,149,106,.3);border-radius:6px;color:var(--accent-light);font-size:11px;letter-spacing:.06em;cursor:pointer;font-family:var(--font-body);transition:all .18s;margin-bottom:8px;}
.btn-copy:hover{background:rgba(184,149,106,.35);}
.btn-copy.copied{background:rgba(74,143,106,.25);border-color:rgba(74,143,106,.4);color:#7AC89A;}

.btn-download{width:100%;padding:15px;background:linear-gradient(135deg,var(--navy) 0%,var(--slate) 100%);color:#fff;border:none;border-radius:10px;font-family:var(--font-serif);font-size:16px;font-weight:400;letter-spacing:.08em;cursor:pointer;margin-top:14px;display:flex;align-items:center;justify-content:center;gap:10px;transition:opacity .2s,transform .18s;box-shadow:0 4px 20px rgba(28,45,62,.2);}
.btn-download:hover{opacity:.92;transform:translateY(-1px);}

/* ── Divider ── */
.divider{height:1px;background:var(--border);margin:20px 0;}

/* ── Toast ── */
.toast{position:fixed;bottom:28px;left:50%;transform:translateX(-50%) translateY(16px);background:var(--navy);color:var(--accent-light);padding:10px 22px;border-radius:50px;font-size:13px;letter-spacing:.04em;opacity:0;transition:all .28s;pointer-events:none;white-space:nowrap;border:1px solid rgba(184,149,106,.25);z-index:999;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

@media(max-width:700px){
  .form-grid,.form-grid.three{grid-template-columns:1fr;}
  .field.full{grid-column:auto;}
  .header{padding:14px 20px;}
  .btn-row{flex-direction:column;}
}
</style>
</head>
<body>

<div class="header">
  <div class="header-logo">飛航模飾</div>
  <div class="header-sub">文章新增工具 v3 · 批次新增</div>
  <div class="header-badge" id="art-count-badge">已輸出：60 篇</div>
</div>

<div class="main">

  <!-- ── STEP 1: 貼上 HTML ── -->
  <div class="panel">
    <div class="panel-header">
      <div class="panel-icon">①</div>
      <div class="panel-title">貼上目前的知識指南 HTML</div>
      <div class="panel-hint">每次操作前先從 Shopline 複製最新版本</div>
    </div>
    <div class="panel-body">
      <textarea class="paste-area loaded" id="html-input" placeholder="把從 Shopline 複製的完整 HTML 貼在這裡…

工具會自動偵測 ARTICLES 陣列，你可以接著新增多篇文章後一次輸出。"></textarea>
      <div class="status-bar success" id="parse-status">✓ 已載入 58 篇文章，可開始填入新文章加入佇列</div>
    </div>
  </div>

  <!-- ── STEP 2: 文章佇列 + 表單 ── -->
  <div class="panel">
    <div class="panel-header">
      <div class="panel-icon">②</div>
      <div class="panel-title">新增文章</div>
      <div class="panel-hint" id="queue-hint">填入資料後加入佇列，可一次新增多篇</div>
    </div>
    <div class="panel-body">

      <!-- Queue -->
      <div class="queue-header">
        <div class="queue-title-row">
          <span class="queue-count" id="queue-count">0</span>
          <span class="queue-label">待新增文章</span>
        </div>
        <button class="btn btn-outline btn-sm" onclick="clearQueue()" id="clear-queue-btn" style="display: none;">清空佇列</button>
      </div>
      <div id="queue-list">
        <div class="queue-empty" id="queue-empty" style="">尚無待新增文章，請填下方表單加入</div>
      </div>

      <div class="divider"></div>

      <!-- Form -->
      <div class="form-section">
        <div class="form-section-title">文章資料</div>

        <div class="form-grid" style="margin-bottom:14px;">
          <div class="field full">
            <label>文章標題 <span class="req">*</span></label>
            <input type="text" id="f-title" placeholder="例：2026 夏季涼感被推薦！材質比較與挑選完整指南">
          </div>
          <div class="field full">
            <label>文章摘要 <span class="req">*</span></label>
            <textarea id="f-desc" placeholder="50–80 字概述，顯示在卡片下方"></textarea>
          </div>
          <div class="field">
            <label>分類標籤 <span class="req">*</span></label>
            <div class="tag-grid">
              <input type="radio" name="tag" id="t-tencel" value="tencel" class="tag-opt"><label for="t-tencel">天絲專區</label>
              <input type="radio" name="tag" id="t-sheet" value="sheet" class="tag-opt"><label for="t-sheet">床包專區</label>
              <input type="radio" name="tag" id="t-bedding" value="bedding" class="tag-opt"><label for="t-bedding">棉被枕頭</label>
              <input type="radio" name="tag" id="t-care" value="care" class="tag-opt"><label for="t-care">清洗保養</label>
              <input type="radio" name="tag" id="t-lifestyle" value="lifestyle" class="tag-opt"><label for="t-lifestyle">臥室佈置</label>
              <input type="radio" name="tag" id="t-collab" value="collab" class="tag-opt"><label for="t-collab">聯名系列</label>
            </div>
          </div>
          <div class="field">
            <label>卡片顯示分類 <span class="req">*</span></label>
            <input type="text" id="f-cat" placeholder="例：棉被選購、天絲知識、床包材質…">
            <div class="field-hint">顯示在卡片左上角金色字</div>
          </div>
          <div class="field full">
            <label>Shopline 頁面路徑 <span class="req">*</span>（/pages/ 後面的部分）</label>
            <input type="text" id="f-slug" placeholder="例：summer-quilt-2026">
          </div>
          <div class="field full">
            <label>封面圖片網址</label>
            <input type="text" id="f-img" placeholder="https://i.ibb.co/... 或 https://shoplineimg.com/...（留空顯示預設色塊）">
          </div>
        </div>

        <div class="form-grid three">
          <div class="field">
            <label>圖片顯示位置</label>
            <div class="pos-grid">
              <input type="radio" name="pos" id="p-tl" value="left top" class="pos-opt"><label for="p-tl">左上</label>
              <input type="radio" name="pos" id="p-tc" value="center top" class="pos-opt"><label for="p-tc">中上</label>
              <input type="radio" name="pos" id="p-tr" value="right top" class="pos-opt"><label for="p-tr">右上</label>
              <input type="radio" name="pos" id="p-cl" value="left center" class="pos-opt" checked=""><label for="p-cl">左中 ★</label>
              <input type="radio" name="pos" id="p-cc" value="center center" class="pos-opt"><label for="p-cc">正中</label>
              <input type="radio" name="pos" id="p-cr" value="right center" class="pos-opt"><label for="p-cr">右中</label>
              <input type="radio" name="pos" id="p-bl" value="left bottom" class="pos-opt"><label for="p-bl">左下</label>
              <input type="radio" name="pos" id="p-bc" value="center bottom" class="pos-opt"><label for="p-bc">中下</label>
              <input type="radio" name="pos" id="p-br" value="right bottom" class="pos-opt"><label for="p-br">右下</label>
            </div>
          </div>
          <div class="field">
            <label>發布日期 <span class="req">*</span></label>
            <input type="date" id="f-date">
          </div>
          <div class="field">
            <label>閱讀時間（分鐘）<span class="req">*</span></label>
            <input type="number" id="f-read" min="1" max="30" placeholder="5">
            <div class="field-hint">800字≈3分 · 1500字≈5分 · 2500字≈8分</div>
          </div>
        </div>

        <div class="btn-row" style="margin-top:18px;">
          <button class="btn btn-secondary" onclick="addToQueue()">＋ 加入佇列</button>
          <button class="btn btn-outline" onclick="clearForm()">清空表單</button>
        </div>
      </div>

    </div>
  </div>

  <!-- ── STEP 3: 輸出 ── -->
  <div class="panel" id="output-panel" style="display: block;">
    <div class="panel-header">
      <div class="panel-icon">③</div>
      <div class="panel-title">輸出完成 — 複製或下載後貼回 Shopline</div>
    </div>
    <div class="panel-body">
      <div class="output-meta-bar" id="output-meta-bar">
    <div class="output-meta-item">✓ 共新增 <strong>2 篇</strong>文章</div>
    <div class="output-meta-item" style="color:var(--muted);font-size:11.5px;"><span style="opacity:.7">1.</span> 涼感床包有用嗎？涼感床包推薦怎麼挑？一次搞懂原理與… &nbsp;·&nbsp; <span style="opacity:.7">2.</span> 涼感材質怎麼選？從聚酯纖維到天絲，拆解市售 5 種…</div>
    <div class="output-meta-item" style="margin-left:auto;">總計 <strong>60 篇</strong></div></div>
      <div class="code-wrap">
        <button class="btn-copy" id="copy-btn" onclick="copyOutput()">複製全部 HTML</button>
        <pre id="output-preview">&lt;!DOCTYPE html&gt;
