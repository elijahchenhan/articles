  <!-- Generate button (fixed bottom) -->
  <div id="generate-bar" style="position: sticky; bottom: 20px; z-index: 50; display: none;">
    <button class="btn btn-success" style="width:100%;padding:15px;font-size:15px;border-radius:12px;box-shadow:0 6px 24px rgba(28,45,62,.25);" onclick="generateHTML()">
      ✦ 將佇列中的 <span id="gen-count">0</span> 篇文章全部加入 HTML 並輸出
    </button>
  </div>

</div>

<div class="toast" id="toast">已清空佇列</div>

<script>
// ── State ──
let currentHTML = '';
let baseArticleCount = 0;
let queue = []; // array of article objects

// ── Tag default cat ──
const TAG_DEFAULT_CAT = {
  tencel:'天絲知識', sheet:'床包選購', bedding:'棉被選購',
  care:'清洗保養', lifestyle:'臥室佈置', collab:'聯名系列'
};
document.querySelectorAll('.tag-opt').forEach(r => {
  r.addEventListener('change', () => {
    const catEl = document.getElementById('f-cat');
    const cur = catEl.value.trim();
    if (!cur || Object.values(TAG_DEFAULT_CAT).includes(cur)) {
      catEl.value = TAG_DEFAULT_CAT[r.value] || '';
    }
  });
});

// ── Default date today ──
document.getElementById('f-date').value = new Date().toISOString().slice(0,10);

// ── Detect HTML on paste ──
const htmlInput = document.getElementById('html-input');
htmlInput.addEventListener('input', detectHTML);
htmlInput.addEventListener('paste', () => setTimeout(detectHTML, 60));

function detectHTML() {
  const val = htmlInput.value.trim();
  if (!val) {
    setStatus('idle', '⟡ 貼上 HTML 後會自動偵測目前文章數量');
    document.getElementById('art-count-badge').textContent = '尚未載入 HTML';
    currentHTML = ''; baseArticleCount = 0;
    return;
  }
  const hasArticles = val.includes('const ARTICLES=[') || val.includes('const ARTICLES = [');
  const titleMatches = (val.match(/title:'/g) || []).length;
  if (!hasArticles || titleMatches === 0) {
    setStatus('error', '✗ 找不到 ARTICLES 陣列，請確認貼入的是正確的知識指南 HTML');
    currentHTML = ''; baseArticleCount = 0;
    document.getElementById('art-count-badge').textContent = '格式錯誤';
    return;
  }
  currentHTML = val;
  baseArticleCount = titleMatches;
  setStatus('success', `✓ 已載入 ${baseArticleCount} 篇文章，可開始填入新文章加入佇列`);
  htmlInput.classList.add('loaded');
  document.getElementById('art-count-badge').textContent = `目前 ${baseArticleCount} 篇`;
}

function setStatus(type, msg) {
  const el = document.getElementById('parse-status');
  el.className = `status-bar ${type}`;
  el.innerHTML = msg;
}

// ── Add article to queue ──
function addToQueue() {
  const title = document.getElementById('f-title').value.trim();
  const desc  = document.getElementById('f-desc').value.trim();
  const tag   = document.querySelector('.tag-opt:checked')?.value || '';
  const cat   = document.getElementById('f-cat').value.trim();
  const slug  = document.getElementById('f-slug').value.trim().replace(/^\/pages\//, '');
  const img   = document.getElementById('f-img').value.trim();
  const pos   = document.querySelector('.pos-opt:checked')?.value || 'center center';
  const date  = document.getElementById('f-date').value;
  const read  = document.getElementById('f-read').value;

  if (!title) { showToast('請填入文章標題'); return; }
  if (!desc)  { showToast('請填入文章摘要'); return; }
  if (!tag)   { showToast('請選擇分類標籤'); return; }
  if (!cat)   { showToast('請填入顯示分類名稱'); return; }
  if (!slug)  { showToast('請填入頁面路徑'); return; }
  if (!date)  { showToast('請選擇發布日期'); return; }
  if (!read)  { showToast('請填入閱讀時間'); return; }

  queue.push({ title, desc, tag, cat, slug, img, pos, date, read: parseInt(read) });
  renderQueue();
  clearForm(true); // clear but keep date
  showToast(`✓ 已加入佇列，目前共 ${queue.length} 篇待新增`);
}

// ── Render queue list ──
function renderQueue() {
  const count = queue.length;
  document.getElementById('queue-count').textContent = count;
  document.getElementById('queue-empty').style.display = count === 0 ? '' : 'none';
  document.getElementById('clear-queue-btn').style.display = count > 0 ? '' : 'none';

  // Generate bar
  const genBar = document.getElementById('generate-bar');
  genBar.style.display = count > 0 && currentHTML ? '' : 'none';
  document.getElementById('gen-count').textContent = count;

  // Cards
  const listEl = document.getElementById('queue-list');
  // Remove existing cards
  listEl.querySelectorAll('.q-card').forEach(el => el.remove());

  queue.forEach((a, i) => {
    const card = document.createElement('div');
    card.className = 'q-card';
    card.innerHTML = `
      <div class="q-num">${i+1}</div>
      <div class="q-body">
        <div class="q-title">${a.title}</div>
        <div class="q-meta">
          <span class="q-tag">${a.cat}</span>
          <span class="q-info">/pages/${a.slug}</span>
          <span class="q-info">📅 ${a.date}</span>
          <span class="q-info">⏱ ${a.read}分鐘</span>
          ${a.img ? '<span class="q-info">🖼 有封面圖</span>' : ''}
        </div>
      </div>
      <button class="q-remove" onclick="removeFromQueue(${i})" title="移除">✕</button>`;
    listEl.appendChild(card);
  });
}

function removeFromQueue(i) {
  const removed = queue.splice(i, 1)[0];
  renderQueue();
  showToast(`已移除：${removed.title.slice(0,20)}…`);
}

function clearQueue() {
  if (queue.length === 0) return;
  queue = [];
  renderQueue();
  showToast('已清空佇列');
}

// ── Generate final HTML ──
function generateHTML() {
  if (!currentHTML) { showToast('請先在步驟①貼上 HTML'); return; }
  if (queue.length === 0) { showToast('佇列中沒有文章，請先填表單加入'); return; }

  // Build all new article entries
  const newEntries = queue.map(a =>
    `\n  {title:'${a.title}',\n   desc:'${a.desc}',\n   cat:'${a.cat}',tag:'${a.tag}',\n   url:B+'/pages/${a.slug}',img:'${a.img}',pos:'${a.pos}',\n   date:'${a.date}',read:${a.read}},`
  ).join('\n');

  // Find insertion point before "];" closing ARTICLES
  let updatedHTML = currentHTML;
  const articlesEndPattern = /(\];[\s\S]*?\/\* ── HELPERS)/;
  const articlesEnd = currentHTML.search(articlesEndPattern);

  if (articlesEnd === -1) {
    const lastReadIdx = currentHTML.lastIndexOf("read:");
    const closingIdx = currentHTML.indexOf('];', lastReadIdx);
    if (closingIdx === -1) {
      showToast('找不到 ARTICLES 結尾，請確認 HTML 格式正確');
      return;
    }
    updatedHTML = currentHTML.slice(0, closingIdx) + newEntries + '\n' + currentHTML.slice(closingIdx);
  } else {
    updatedHTML = currentHTML.slice(0, articlesEnd) + newEntries + '\n' + currentHTML.slice(articlesEnd);
  }

  // Update counts
  const newCount = baseArticleCount + queue.length;
  updatedHTML = updatedHTML
    .replace(/(\d+) 篇專業文章/g, `${newCount} 篇專業文章`)
    .replace(/(\d+)篇專業文章/g, `${newCount}篇專業文章`)
    .replace(/(\d+)篇寢具專業知識/g, `${newCount}篇寢具專業知識`)
    .replace(/(\d+) 篇天絲/g, `${newCount} 篇天絲`)
    .replace(/54篇/g, `${newCount}篇`)
    .replace(/"54 /g, `"${newCount} `);

  // Update dateModified
  const today = new Date().toISOString().slice(0,10);
  updatedHTML = updatedHTML.replace(/"dateModified": "[^"]+"/g, `"dateModified": "${today}"`);

  window._updatedHTML = updatedHTML;

  // Show output panel
  const outputPanel = document.getElementById('output-panel');
  outputPanel.style.display = 'block';
  outputPanel.scrollIntoView({ behavior:'smooth', block:'start' });

  // Preview
  const preview = updatedHTML.length > 4000
    ? updatedHTML.slice(0, 2500) + '\n\n… [中間省略，完整內容請下載或複製全部] …\n\n' + updatedHTML.slice(-800)
    : updatedHTML;
  document.getElementById('output-preview').textContent = preview;

  // Meta bar
  const titles = queue.map((a,i) => `<span style="opacity:.7">${i+1}.</span> ${a.title.slice(0,25)}${a.title.length>25?'…':''}`).join(' &nbsp;·&nbsp; ');
  document.getElementById('output-meta-bar').innerHTML = `
    <div class="output-meta-item">✓ 共新增 <strong>${queue.length} 篇</strong>文章</div>
    <div class="output-meta-item" style="color:var(--muted);font-size:11.5px;">${titles}</div>
    <div class="output-meta-item" style="margin-left:auto;">總計 <strong>${newCount} 篇</strong></div>`;

  document.getElementById('art-count-badge').textContent = `已輸出：${newCount} 篇`;
  showToast(`✦ 已將 ${queue.length} 篇文章加入 HTML，共 ${newCount} 篇`);
}

// ── Copy ──
function copyOutput() {
  const html = window._updatedHTML;
  if (!html) return;
  navigator.clipboard.writeText(html).then(() => {
    const btn = document.getElementById('copy-btn');
    btn.textContent = '已複製 ✓';
    btn.classList.add('copied');
    setTimeout(() => { btn.textContent = '複製全部 HTML'; btn.classList.remove('copied'); }, 2500);
    showToast('已複製完整 HTML，可直接貼到 Shopline');
  });
}

// ── Download ──
function downloadHTML() {
  const html = window._updatedHTML;
  if (!html) return;
  const blob = new Blob([html], { type: 'text/html;charset=utf-8' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `flightmode-guide-${new Date().toISOString().slice(0,10)}.html`;
  a.click();
  URL.revokeObjectURL(url);
  showToast('↓ 下載中…');
}

// ── Clear form ──
function clearForm(keepDate = false) {
  ['f-title','f-cat','f-slug','f-img','f-desc','f-read'].forEach(id => {
    document.getElementById(id).value = '';
  });
  document.querySelectorAll('.tag-opt').forEach(r => r.checked = false);
  document.querySelectorAll('.pos-opt').forEach(r => r.checked = false);
  document.getElementById('p-cl').checked = true;
  if (!keepDate) {
    document.getElementById('f-date').value = new Date().toISOString().slice(0,10);
  }
}

// ── Toast ──
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2600);
}
</script>


